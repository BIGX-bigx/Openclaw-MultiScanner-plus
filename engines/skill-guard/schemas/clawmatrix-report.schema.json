{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClawMatrix report",
  "type": "object",
  "required": ["tool", "generated_at", "subject", "summary", "layers"],
  "properties": {
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "generated_at": { "type": "string" },
    "subject": { "type": "object" },
    "summary": {
      "type": "object",
      "required": ["finding_count", "highest_severity", "findings_by_severity"],
      "properties": {
        "finding_count": { "type": "integer" },
        "highest_severity": { "type": "string" },
        "findings_by_severity": { "type": "object" }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "severity", "title"],
              "properties": {
                "id": { "type": "string" },
                "severity": { "type": "string" },
                "title": { "type": "string" },
                "evidence": {}
              }
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
